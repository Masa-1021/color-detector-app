FROM python:3.11-slim

WORKDIR /app

# oracledb Thin モードは Instant Client 不要
RUN pip install --no-cache-dir \
    paho-mqtt \
    oracledb

COPY mqtt_oracle_bridge.py .
COPY equipment_status.py .
COPY message_queue.py .
COPY config/ ./config/

ENV PYTHONUNBUFFERED=1

CMD ["python3", "mqtt_oracle_bridge.py"]
