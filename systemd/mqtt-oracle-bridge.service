[Unit]
Description=MQTT to Oracle Bridge Service
After=network.target mosquitto.service
Requires=mosquitto.service

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/Apps/color-detector-app
ExecStart=/usr/bin/python3 /home/pi/Apps/color-detector-app/mqtt_oracle_bridge.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
