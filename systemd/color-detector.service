[Unit]
Description=Circle Detector - Color Detection Web Application
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/Apps/color-detector-app
ExecStart=/usr/bin/python3 -m circle_detector.app
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
